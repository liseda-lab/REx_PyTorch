# Copy this file to .env and fill in your keys
# cp .env.example .env

# --- GPT API (--llm_api 1 --llm_model gpt) ---
OPENAI_API_KEY=sk-YourOpenAIKeyHere
OPENAI_MODEL=gpt-4o-mini

# --- Qwen API via HuggingFace (--llm_api 1 --llm_model qwen) ---
HF_API_BASE=https://router.huggingface.co/together/v1
HF_API_KEY=hf_YourHuggingFaceKeyHere
HF_MODEL=Qwen/Qwen3.5-9B
